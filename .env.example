# Strongly recommended: require this bearer token from callers. Without it,
# anything that can reach this server can make real, billed calls against
# your IBM Bob entitlement.
BOB_SERVER_API_KEY=

# Optional - defaults shown.
#BOB_SERVER_PORT=8766
#BOB_SERVER_HOST=127.0.0.1

# Optional - override if bobshell isn't at the usual global npm location
# (see "Locating bob.js" in the README).
#BOB_BUNDLE_PATH=
